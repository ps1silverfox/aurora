{
  "name": "aurora-cms-ts",
  "version": "0.0.1",
  "description": "Aurora CMS — TypeScript / NestJS / Oracle 19c rewrite",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:oracle": "cross-env DB_DRIVER=oracle jest --config jest.integration.config.ts",
    "test:e2e": "playwright test",
    "db:migrate": "ts-node src/db/migrate.ts",
    "license-check": "license-checker --production --onlyAllow \"MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.58.1",
    "@opentelemetry/exporter-prometheus": "^0.203.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "jsonpath-plus": "^10.4.0",
    "jwks-rsa": "^4.0.1",
    "oracledb": "^6.10.0",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "overrides": {
    "eslint": {
      "ajv": "^6.14.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/oracledb": "^6.10.3",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jiti": "^2.0.0",
    "jsonwebtoken": "^9.0.3",
    "license-checker": "^25.0.1",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
